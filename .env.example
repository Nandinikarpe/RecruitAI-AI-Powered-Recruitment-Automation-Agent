# Supabase (Python client — not Next.js)
# You can use the same values as NEXT_PUBLIC_* from the Supabase dashboard.
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_publishable_key
# Recommended for production / when RLS is enabled (Dashboard → Settings → API → service_role):
SUPABASE_SERVICE_KEY=

# Google Gemini (free tier: use a Flash model)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# JWT Auth
SECRET_KEY=your_super_secret_jwt_key_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gmail SMTP
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# App — Streamlit uses BACKEND_URL from here (python-dotenv) or from Streamlit Cloud secrets
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8501
# After starting the API, verify Supabase: GET http://localhost:8000/health/supabase
