# Google Gemini (free tier: use a Flash model)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# JWT Auth (required for login sessions)
SECRET_KEY=your_super_secret_jwt_key_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Local JSON storage (no external database)
DATA_DIR=data

# Gmail SMTP (optional — needed only for email features)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8501
